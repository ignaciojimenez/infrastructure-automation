---
# Global Variables - Common to all hosts
# Copy to main.yml and fill in your values.
# Secrets belong in vault.yml, not here.

# ============================================================
# Smart Defaults
# ============================================================

ansible_host: "{{ inventory_hostname }}"

# Infrastructure user — defaults to the user running Ansible
infrastructure_user: "{{ vault_infrastructure_user | default(lookup('env', 'USER')) }}"
ansible_user: "{{ infrastructure_user }}"

# User paths
primary_user: "{{ ansible_user }}"
home_dir: "/home/{{ primary_user }}"
scripts_dir: "/home/{{ primary_user }}/.scripts"
logs_dir: "/home/{{ primary_user }}/.logs"

# Bootstrap fallback user order
ansible_ssh_common_args: '-o ConnectTimeout=5'
bootstrap_fallback_users:
  - "{{ infrastructure_user }}"
  - pi
  - root

# ============================================================
# Locale / Timezone
# ============================================================
locale: "en_US.UTF-8"
timezone: "UTC"  # e.g. "Europe/London", "America/New_York"

# ============================================================
# Git (from vault)
# ============================================================
git_name: "{{ vault_git_name }}"
git_mail: "{{ vault_git_mail }}"

# ============================================================
# GitHub (for SSH key provisioning)
# ============================================================
gh_profile: "{{ vault_gh_profile }}"
gh_keys: "https://github.com/{{ gh_profile }}.keys"

# ============================================================
# Backup encryption (age public key — from vault)
# ============================================================
backup_age_pubkey: "{{ vault_backup_age_pubkey | default('') }}"

# ============================================================
# Monitoring tokens (from vault)
# ============================================================
logging_token: "{{ vault_logging_token }}"
alert_token: "{{ vault_alert_token }}"

# ============================================================
# Curlbin (offsite backup storage)
# ============================================================
curlbin_host: "{{ vault_curlbin_host | default('curlbin.example.com') }}"
curlbin_user: "{{ vault_curlbin_user }}"
curlbin_password: "{{ vault_curlbin_password }}"

# ============================================================
# System toggles
# ============================================================
enable_unattended_upgrades: true
enable_monitoring: true
