# {{ agent_access_user }} — read-only agent access
# Managed by Ansible — do not edit manually

# Process inspection
{{ agent_access_user }} ALL=(ALL) NOPASSWD: /usr/bin/pgrep *

# Service status (read-only)
{{ agent_access_user }} ALL=(ALL) NOPASSWD: /usr/sbin/service * status
{{ agent_access_user }} ALL=(ALL) NOPASSWD: /usr/sbin/service -e

# Firewall state (read-only)
{{ agent_access_user }} ALL=(ALL) NOPASSWD: /sbin/pfctl -s info
{{ agent_access_user }} ALL=(ALL) NOPASSWD: /sbin/pfctl -s state
{{ agent_access_user }} ALL=(ALL) NOPASSWD: /sbin/pfctl -s rules

# OPNsense service status
{{ agent_access_user }} ALL=(ALL) NOPASSWD: /usr/local/sbin/configctl service list
{{ agent_access_user }} ALL=(ALL) NOPASSWD: /usr/local/sbin/configctl unbound status
{{ agent_access_user }} ALL=(ALL) NOPASSWD: /usr/local/sbin/configctl wireguard showconf

# CrowdSec read-only
# No-args variants listed separately — a trailing `*` requires at least one
# argument, so `cscli decisions list` alone would not match `... list *`.
{{ agent_access_user }} ALL=(ALL) NOPASSWD: /usr/local/bin/cscli decisions list
{{ agent_access_user }} ALL=(ALL) NOPASSWD: /usr/local/bin/cscli decisions list *
{{ agent_access_user }} ALL=(ALL) NOPASSWD: /usr/local/bin/cscli alerts list
{{ agent_access_user }} ALL=(ALL) NOPASSWD: /usr/local/bin/cscli alerts list *
{{ agent_access_user }} ALL=(ALL) NOPASSWD: /usr/local/bin/cscli metrics
{{ agent_access_user }} ALL=(ALL) NOPASSWD: /usr/local/bin/cscli metrics *
