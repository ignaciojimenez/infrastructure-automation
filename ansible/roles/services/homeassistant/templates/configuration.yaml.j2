# Home Assistant Configuration
# Managed by Ansible - Manual changes will be overwritten

# Core configuration
homeassistant:
  external_url: "{{ homeassistant_external_url | default('http://homeassistant.local:8123') }}"
  internal_url: "http://localhost:8123"
  customize:
    climate.tado_smart_thermostat_ru3393984256:
      friendly_name: "Salón Thermostat"
    climate.tado_smart_radiator_thermostat_va1065432832:
      friendly_name: "Salón Radiator 1"
    climate.tado_smart_radiator_thermostat_va2323724032:
      friendly_name: "Salón Radiator 2"
    climate.tado_smart_thermostat_su3182126080:
      friendly_name: "Bedroom Thermostat"
    climate.tado_smart_radiator_thermostat_va0290656256:
      friendly_name: "Bedroom Radiator"
    climate.tado_smart_radiator_thermostat_va2220036096:
      friendly_name: "Office Radiator"
    climate.tado_smart_radiator_thermostat_va3363583744:
      friendly_name: "Hallway Radiator"
    climate.tado_smart_radiator_thermostat_va0612513536:
      friendly_name: "Bathroom Radiator"

# Loads default set of integrations. Do not remove.
default_config:

# Load frontend themes from the themes folder
frontend:
  themes: !include_dir_merge_named themes

# Text-to-speech
tts:
  - platform: google_translate

automation: !include automations.yaml
script: !include scripts.yaml
scene: !include scenes.yaml

#### Manual configs from this point
group: !include groups.yaml

{% if homeassistant_lights | default([]) | length > 0 %}
# Light Groups
light:
  - platform: group
    name: All lights
    entities:
{% for light in homeassistant_lights %}
      - {{ light }}
{% endfor %}
{% endif %}

# Logger configuration
logger:
  default: warning
  logs:
    custom_components.wyzeapi: debug

# Input Select
input_select:
  tado_mode:
    name: Tado Mode
    options:
      - Home
      - Away
    initial: Home
    icon: mdi:home-thermometer

# Input Booleans
input_boolean:
  guest_mode:
    name: Guest Mode
    icon: mdi:account-multiple
  train_notified_today:
    name: Train Notification Sent Today
    icon: mdi:train

# Template sensors (modern syntax)
template:
  - binary_sensor:
      - name: "Wyze Online"
        unique_id: wyze_online
        device_class: connectivity
        state: >
          {{ '{{ states(\'light.floor_lamp_new\') not in [\'unavailable\', \'unknown\'] }}' }}
      # Presence detection
      - name: "Home Occupied"
        unique_id: home_occupied
        device_class: occupancy
        state: >
          {{ '{{ is_state("group.persons", "home") }}' }}
        icon: >
          {{ '{% if is_state("group.persons", "home") %}' }}
            mdi:home-account
          {{ '{% else %}' }}
            mdi:home-outline
          {{ '{% endif %}' }}
      
      # Primary user presence (Companion App device tracker)
      - name: "{{ ha_primary_person_display | default('Primary') }} Presence"
        unique_id: "{{ ha_primary_person_display | default('primary') | lower }}_presence_combined"
        device_class: presence
        state: '{{ "{{ is_state(\"" }}{{ ha_primary_device_tracker | default("device_tracker.phone") }}{{ "\", \"home\") }}" }}'

      # Secondary user presence (Companion App device tracker)
      - name: "{{ ha_secondary_person_display | default('Secondary') }} Presence"
        unique_id: "{{ ha_secondary_person_display | default('secondary') | lower }}_presence_combined"
        device_class: presence
        state: '{{ "{{ is_state(\"" }}{{ ha_secondary_device_tracker | default("device_tracker.phone_secondary") }}{{ "\", \"home\") }}" }}'

      # Amp power control — is any source feeding the Pioneer? OR of every input:
      # hifipi AirPlay/Spotify/MPD actively playing, vinyl detected on the
      # turntable (MQTT push from vinylstreamer — instant, unlike the ~10s MPD
      # poll that also covers the same playback), or the TV powered on. Drives
      # the Shelly plug (switch.living_room_shellyplugsg3_pioneer) via automations.
      - name: "Amp Source Active"
        unique_id: amp_source_active
        device_class: running
        state: >
          {{ '{{ is_state("binary_sensor.shairport_sync_hifipi_playing", "on") or is_state("binary_sensor.raspotify_hifipi_playing", "on") or is_state("binary_sensor.vinyl_vinylstreamer_playing", "on") or is_state("media_player.music_player_daemon", "playing") or is_state("media_player.cobi_tv_3", "on") }}' }}
  - sensor:
      # Amp input selection — which source the RM IR switch should select once the
      # blaster is installed (RM not yet present; this is the hook it will consume).
      # Active Pi playback wins over a merely powered-on TV. Values: pi / tv / none.
      - name: "Amp Active Source"
        unique_id: amp_active_source
        state: >
          {{ '{% if is_state("binary_sensor.shairport_sync_hifipi_playing", "on") or is_state("binary_sensor.raspotify_hifipi_playing", "on") or is_state("binary_sensor.vinyl_vinylstreamer_playing", "on") or is_state("media_player.music_player_daemon", "playing") %}pi{% elif is_state("media_player.cobi_tv_3", "on") %}tv{% else %}none{% endif %}' }}

# Amp plug cycling watchdog input — how many times the plug switched ON in the
# last rolling hour. Phantom-start debounce lives in detect_audio on vinylstreamer
# (the only place that sees the raw signal); the amp-on automation is deliberately
# instant, so this counter is the safety net that pages instead of adding delay.
sensor:
  - platform: history_stats
    name: "Amp Plug On Count 1h"
    entity_id: switch.living_room_shellyplugsg3_pioneer
    state: "on"
    type: count
    duration: "01:00:00"
    end: "{{ '{{ now() }}' }}"

# MQTT entities — Raspotify (Spotify Connect) now-playing state from hifipi.
# shairport-sync publishes its own entities via MQTT autodiscovery; librespot
# has no discovery, so its play/stop state is defined explicitly here.
mqtt:
  binary_sensor:
    # Vinyl playback detected on the turntable — pushed by detect_audio on
    # vinylstreamer the moment sustained signal is confirmed. Feeds
    # amp_source_active so the plug reacts instantly (the MPD entity covers
    # the same playback but only via ~10s polling).
    - name: "Playing"
      unique_id: vinyl_vinylstreamer_playing
      state_topic: "vinyl/vinylstreamer/playing"
      payload_on: "1"
      payload_off: "0"
      device_class: running
      icon: mdi:record-player
      device:
        identifiers: ["vinyl_vinylstreamer"]
        name: "Vinyl (vinylstreamer)"
        manufacturer: "detect_audio"
        model: "Turntable stream"
    - name: "Playing"
      unique_id: raspotify_hifipi_playing
      state_topic: "{{ raspotify_mqtt_base_topic | default('raspotify/hifipi') }}/playing"
      payload_on: "1"
      payload_off: "0"
      device_class: running
      icon: mdi:spotify
      device:
        identifiers: ["raspotify_hifipi"]
        name: "Raspotify (hifipi)"
        manufacturer: "librespot"
        model: "Spotify Connect"
  sensor:
    - name: "State"
      unique_id: raspotify_hifipi_state
      state_topic: "{{ raspotify_mqtt_base_topic | default('raspotify/hifipi') }}/state"
      icon: mdi:spotify
      device:
        identifiers: ["raspotify_hifipi"]
        name: "Raspotify (hifipi)"
        manufacturer: "librespot"
        model: "Spotify Connect"

# Slack notifications (webhooks stored in secrets.yaml)
rest_command:
  slack_notify:
    url: !secret slack_log_webhook
    method: post
    headers:
      Content-Type: application/json
    payload: >
      {
        "text": "{{ '{{ message }}' }}"
      }
  slack_alert:
    url: !secret slack_alert_webhook
    method: post
    headers:
      Content-Type: application/json
    payload: >
      {
        "text": "{{ '{{ message }}' }}"
      }

# HTTP configuration for reverse proxy (Cloudflare Tunnel)
http:
  use_x_forwarded_for: true
  trusted_proxies:
    - 127.0.0.1
    - ::1
  ip_ban_enabled: true
  login_attempts_threshold: 5

# Shell commands
shell_command:
  notify_train_platform: '/config/scripts/notify_train_platform.sh'
  tado_set_away: '/config/scripts/tado_presence.sh AWAY'
  tado_set_home: '/config/scripts/tado_presence.sh HOME'
