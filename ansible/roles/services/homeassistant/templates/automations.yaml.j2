# Home Assistant Automations - Managed by Ansible

# Lights on when dark — fires at sunset (if someone home) or on arrival (if already dark)
- id: '1614473127522'
  alias: Lights on when dark
  trigger:
    - platform: numeric_state
      entity_id: sun.sun
      value_template: '{{ "{{ state_attr(\"sun.sun\", \"elevation\") }}" }}'
      below: '1.5'
    - platform: state
      entity_id: group.persons
      to: "home"
      for:
        minutes: 2
  condition:
    - condition: numeric_state
      entity_id: sun.sun
      attribute: elevation
      below: 1.5
    - condition: state
      entity_id: group.persons
      state: home
    - condition: state
      entity_id: light.all_lights
      state: "off"
  action:
    - service: scene.turn_on
      target:
        entity_id: scene.chill
  mode: single

# Lights off automations
- id: '1638915083194'
  alias: lights off - week
  trigger:
    - platform: time
      at: '00:30:00'
  condition:
    - condition: time
      weekday: [mon, tue, wed, thu]
  action:
    - service: light.turn_off
      target:
        entity_id: light.all_lights
  mode: single

- id: '1638916130644'
  alias: lights off - weekend
  trigger:
    - platform: time
      at: '02:30:00'
  condition:
    - condition: time
      weekday: [fri, sat, sun]
  action:
    - service: light.turn_off
      target:
        entity_id: light.all_lights
  mode: single

# Daily backups
- id: '1687725012156'
  alias: Daily backups
  trigger:
    - platform: time
      at: '03:00:00'
  action:
    - service: backup.create
  mode: single

 # Away/Home mode
# Uses Tado API (presenceLock) to properly set home/away without fighting
# Tado's own schedules. Template trigger treats "not_home" and "unknown" as away,
# preventing hourly device-tracker polling blips from resetting the timer.
- id: "away_mode_everyone_left"
  alias: "Away Mode - Everyone Left"
  trigger:
    - platform: template
      value_template: >
        {{ '{{ states("group.persons") != "home" }}' }}
      for:
        minutes: 10
  condition:
    - condition: state
      entity_id: input_boolean.guest_mode
      state: "off"
  action:
    - service: shell_command.tado_set_away
    - service: input_select.select_option
      target:
        entity_id: input_select.tado_mode
      data:
        option: "Away"
    - service: light.turn_off
      target:
        entity_id: light.all_lights
  mode: single

- id: "home_mode_first_arrives"
  alias: "Home Mode - First Person Arrives"
  trigger:
    - platform: template
      value_template: >
        {{ '{{ states("group.persons") == "home" }}' }}
      for:
        minutes: 3
  action:
    - service: shell_command.tado_set_home
    - service: input_select.select_option
      target:
        entity_id: input_select.tado_mode
      data:
        option: "Home"
    - service: rest_command.slack_notify
      data:
        message: "Welcome home! Tado set to HOME."
  mode: single

# Guest mode
- id: "guest_mode_enabled"
  alias: "Guest Mode - Disable Auto Away"
  trigger:
    - platform: state
      entity_id: input_boolean.guest_mode
      to: "on"
  action:
    - service: automation.turn_off
      target:
        entity_id: automation.away_mode_everyone_left
  mode: single

- id: "guest_mode_disabled"
  alias: "Guest Mode Off - Enable Auto Away"
  trigger:
    - platform: state
      entity_id: input_boolean.guest_mode
      to: "off"
  action:
    - service: automation.turn_on
      target:
        entity_id: automation.away_mode_everyone_left
  mode: single

# Wyze bulb monitoring - alerts when specific bulbs go offline/online
- id: "wyze_bulb_offline_alert"
  alias: "Wyze Bulb Offline Alert"
  trigger:
    - platform: state
      entity_id:
        - light.floor_lamp
        - light.floor_lamp_new
        - light.book_floor_lamp
        - light.table_lamp
      to: "unavailable"
      for:
        minutes: 5
  action:
    - service: rest_command.slack_notify
      data:
        message: "{{ '{{' }} \"⚠️ Wyze bulb offline: \" ~ (trigger.to_state.attributes.friendly_name | default(trigger.entity_id)) {{ '}}' }}"
  mode: parallel

- id: "wyze_bulb_online_recovery"
  alias: "Wyze Bulb Online Recovery"
  trigger:
    - platform: state
      entity_id:
        - light.floor_lamp
        - light.floor_lamp_new
        - light.book_floor_lamp
        - light.table_lamp
      from: "unavailable"
  action:
    - service: rest_command.slack_notify
      data:
        message: "{{ '{{' }} \"✅ Wyze bulb back online: \" ~ (trigger.to_state.attributes.friendly_name | default(trigger.entity_id)) {{ '}}' }}"
  mode: parallel

# HomeKit heating availability monitoring
- id: "homekit_tado_climate_offline_alert"
  alias: "HomeKit Tado Climate Offline Alert"
  trigger:
    - platform: state
      entity_id:
        - climate.tado_smart_thermostat_ru3393984256
        - climate.tado_smart_thermostat_su3182126080
        - climate.tado_smart_radiator_thermostat_va3363583744
        - climate.tado_smart_radiator_thermostat_va0290656256
        - climate.tado_smart_radiator_thermostat_va2220036096
        - climate.tado_smart_radiator_thermostat_va0612513536
        - climate.tado_smart_radiator_thermostat_va1065432832
        - climate.tado_smart_radiator_thermostat_va2323724032
      to: "unavailable"
      # 20 min: these entities are monitoring-only (heads heat on their local
      # schedule regardless), so short RF blips are immaterial — don't page them.
      for:
        minutes: 20
  # Global 6h cooldown: a flapping head pages once per 6h, not every outage.
  # Heads keep heating on their local schedule while unavailable in HA, so a
  # page delayed by the shared cooldown is an accepted trade for zero helpers.
  condition:
    - condition: template
      value_template: "{{ '{{' }} this.attributes.last_triggered is none or now() - this.attributes.last_triggered > timedelta(hours=6) {{ '}}' }}"
  action:
    - service: rest_command.slack_alert
      data:
        message: "{{ '{{' }} \"⚠️ Heating offline: \" ~ (trigger.to_state.attributes.friendly_name | default(trigger.entity_id)) {{ '}}' }}"
  mode: parallel

- id: "homekit_tado_climate_online_recovery"
  alias: "HomeKit Tado Climate Online Recovery"
  trigger:
    - platform: state
      entity_id:
        - climate.tado_smart_thermostat_ru3393984256
        - climate.tado_smart_thermostat_su3182126080
        - climate.tado_smart_radiator_thermostat_va3363583744
        - climate.tado_smart_radiator_thermostat_va0290656256
        - climate.tado_smart_radiator_thermostat_va2220036096
        - climate.tado_smart_radiator_thermostat_va0612513536
        - climate.tado_smart_radiator_thermostat_va1065432832
        - climate.tado_smart_radiator_thermostat_va2323724032
      from: "unavailable"
  action:
    - service: rest_command.slack_notify
      data:
        message: "{{ '{{' }} \"✅ Heating back online: \" ~ (trigger.to_state.attributes.friendly_name | default(trigger.entity_id)) {{ '}}' }}"
  mode: parallel

# Eve door sensors - notification when doors open while nobody is home
# Only triggers if group.persons has been not_home for at least 5 minutes
# (avoids false alerts when leaving home and crossing geofence)
# Sensor mapping:
#   binary_sensor.eve_door_20ebn9901_door   -> Balcony Door
#   binary_sensor.eve_door_20ebn9901_door_2 -> Entrance Door
- id: "eve_door_open_while_away"
  alias: "Door Opened While Away"
  trigger:
    - platform: state
      entity_id: binary_sensor.eve_door_20ebn9901_door
      to: "on"
      id: balcony
    - platform: state
      entity_id: binary_sensor.eve_door_20ebn9901_door_2
      to: "on"
      id: entrance
  condition:
    - condition: state
      entity_id: group.persons
      state: "not_home"
      for:
        minutes: 5
  action:
    - service: rest_command.slack_alert
      data:
        message: "{{ '{{' }} \"🚪 Balcony\" if trigger.id == \"balcony\" else \"🚪 Entrance\" {{ '}}' }} door opened while away"
  mode: single

# ============================================================
# TRAIN COMMUTE NOTIFICATION
# ============================================================
# Sends train platform info when Choco leaves home on weekday mornings

- id: "train_commute_notification"
  alias: "Train Commute - Platform Notification"
  description: "Send NS train platform info when leaving for work (combined Tado + Companion app)"
  trigger:
    - platform: state
      entity_id: "{{ ha_primary_presence_sensor | default('binary_sensor.primary_presence') }}"
      from: "on"
      to: "off"
  condition:
    - condition: time
      after: "07:00:00"
      before: "10:00:00"
      weekday:
        - mon
        - tue
        - wed
        - thu
        - fri
    - condition: state
      entity_id: input_boolean.train_notified_today
      state: "off"
  action:
    - service: input_boolean.turn_on
      target:
        entity_id: input_boolean.train_notified_today
    - service: shell_command.notify_train_platform
  mode: single

- id: "train_notification_reset"
  alias: "Train Notification - Daily Reset"
  description: "Reset train notification flag at midnight"
  trigger:
    - platform: time
      at: "00:00:00"
  action:
    - service: input_boolean.turn_off
      target:
        entity_id: input_boolean.train_notified_today
  mode: single

# ============================================================
# SECURITY MONITORING
# ============================================================
- id: 'security_login_failure_alert'
  alias: 'Security: Failed Login Attempts Alert'
  description: 'Alert on failed login attempts and IP bans via Slack'
  trigger:
    - platform: persistent_notification
      update_type: added
  condition:
    - condition: template
      value_template: >
        {{ '{% set message = trigger.notification.message | default("") %}' }}
        {{ '{% set title = trigger.notification.title | default("") %}' }}
        {{ '{{ "Login attempt" in message or "login attempt" in message or' }}
           {{ '"Too many login attempts" in message or "Banned" in message or' }}
           {{ '"invalid authentication" in message }}' }}
  action:
    - service: rest_command.slack_alert
      data:
        message: >
          {{ '🚨 Security Alert - {{ now().strftime("%Y-%m-%d %H:%M:%S") }}' }}
          
          {{ '{% set msg = trigger.notification.message | default("") %}' }}
          {{ '{% set title = trigger.notification.title | default("") %}' }}
          {{ '{% if "Too many login attempts" in msg or "Banned" in msg %}' }}
          {{ '*IP BANNED*' }}
          {{ '{% elif "invalid authentication" in msg or "login attempt" in msg %}' }}
          {{ '*Failed Login Attempt*' }}
          {{ '{% else %}' }}
          {{ '*Security Event*' }}
          {{ '{% endif %}' }}
          
          {{ '{{ title }}' }}
          {{ '{{ msg }}' }}
  mode: queued
  max: 10

# ─── Shelly Gas detectors (mains-powered, always online) ───────────────────
# Life-safety: the detector's own siren is primary; Slack is the remote-warning
# layer. Critical events (alarm, sensor fault) -> slack_alert; the rest -> notify.
# Friendly name resolves to the HA Area if set (assign both units to an Area for
# clean messages), else falls back to the device's entity name.

- id: "shelly_gas_alarm"
  alias: "Shelly Gas - Alarm"
  trigger:
    - platform: state
      entity_id:
        - sensor.shellygas_8c4f0059f510_gas_detected
        - sensor.shellygas_8c4f0059fb5f_gas_detected
      to:
        - "mild"
        - "heavy"
  action:
    - service: rest_command.slack_alert
      data:
        message: "{{ '{{' }} \"🚨🔥 GAS ALARM — \" ~ (area_name(trigger.entity_id) | default(trigger.to_state.attributes.friendly_name | replace(\" Gas detected\", \"\"), true)) ~ \": \" ~ (trigger.to_state.state | upper) ~ \" (\" ~ states(trigger.entity_id | replace(\"_gas_detected\", \"_gas_concentration\")) ~ \" ppm)\" {{ '}}' }}"
  mode: parallel

- id: "shelly_gas_self_test"
  alias: "Shelly Gas - Self-test Running"
  trigger:
    - platform: state
      entity_id:
        - sensor.shellygas_8c4f0059f510_gas_detected
        - sensor.shellygas_8c4f0059fb5f_gas_detected
      to: "test"
  action:
    - service: rest_command.slack_notify
      data:
        message: "{{ '{{' }} \"🧪 Gas detector self-test running — \" ~ (area_name(trigger.entity_id) | default(trigger.to_state.attributes.friendly_name | replace(\" Gas detected\", \"\"), true)) {{ '}}' }}"
  mode: parallel

- id: "shelly_gas_cleared"
  alias: "Shelly Gas - Cleared"
  trigger:
    - platform: state
      entity_id:
        - sensor.shellygas_8c4f0059f510_gas_detected
        - sensor.shellygas_8c4f0059fb5f_gas_detected
      from:
        - "mild"
        - "heavy"
      to: "none"
  action:
    - service: rest_command.slack_alert
      data:
        message: "{{ '{{' }} \"✅ Gas cleared — \" ~ (area_name(trigger.entity_id) | default(trigger.to_state.attributes.friendly_name | replace(\" Gas detected\", \"\"), true)) {{ '}}' }}"
  mode: parallel

- id: "shelly_gas_fault"
  alias: "Shelly Gas - Sensor Fault or Offline"
  trigger:
    - platform: state
      entity_id:
        - sensor.shellygas_8c4f0059f510_operation
        - sensor.shellygas_8c4f0059fb5f_operation
      to:
        - "fault"
        - "unavailable"
      for:
        minutes: 5
  action:
    - service: rest_command.slack_alert
      data:
        message: "{{ '{{' }} \"⚠️ Gas detector FAULT/OFFLINE — \" ~ (area_name(trigger.entity_id) | default(trigger.to_state.attributes.friendly_name | replace(\" Operation\", \"\"), true)) ~ \" (state: \" ~ trigger.to_state.state ~ \")\" {{ '}}' }}"
  mode: parallel

- id: "shelly_gas_fault_recovery"
  alias: "Shelly Gas - Sensor Recovered"
  trigger:
    - platform: state
      entity_id:
        - sensor.shellygas_8c4f0059f510_operation
        - sensor.shellygas_8c4f0059fb5f_operation
      from:
        - "fault"
        - "unavailable"
      to: "normal"
  condition:
    # Mirror the FAULT automation's 5-min debounce: only announce recovery if the
    # sensor was genuinely unavailable/fault long enough to have raised a FAULT
    # alert. Suppresses phantom "back to normal" messages from brief CoIoT/Wi-Fi
    # poll blips and from HA restarts (where the prior-state duration is ~0).
    - condition: template
      value_template: "{{ '{{' }} trigger.from_state is not none and (trigger.to_state.last_changed - trigger.from_state.last_changed).total_seconds() >= 300 {{ '}}' }}"
  action:
    - service: rest_command.slack_alert
      data:
        message: "{{ '{{' }} \"✅ Gas detector back to normal — \" ~ (area_name(trigger.entity_id) | default(trigger.to_state.attributes.friendly_name | replace(\" Operation\", \"\"), true)) {{ '}}' }}"
  mode: parallel

# ─── Shelly Plus Smoke detector (battery-powered, sleeping device) ──────────
# Life-safety: the detector's own siren is primary; Slack is the remote layer.
# Alarm / cleared / low-battery / offline -> slack_alert; recovery -> notify.
# Test the alarm path by pressing the unit's physical test button (it drives
# the smoke binary_sensor "on", firing the alarm automation to #home-alerts).
# Offline uses a long (26h) debounce: this device only wakes to report
# periodically, so a short "unavailable" window is normal, not a fault.

- id: "shelly_smoke_alarm"
  alias: "Shelly Smoke - Alarm"
  trigger:
    - platform: state
      entity_id:
        - binary_sensor.shellyplussmoke_3076f523fd68_smoke
      to: "on"
  action:
    - service: rest_command.slack_alert
      data:
        message: "{{ '{{' }} \"🚨🔥 SMOKE ALARM — \" ~ (area_name(trigger.entity_id) | default(trigger.to_state.attributes.friendly_name | replace(\" Smoke\", \"\"), true)) {{ '}}' }}"
  mode: parallel

- id: "shelly_smoke_cleared"
  alias: "Shelly Smoke - Cleared"
  trigger:
    - platform: state
      entity_id:
        - binary_sensor.shellyplussmoke_3076f523fd68_smoke
      from: "on"
      to: "off"
  action:
    - service: rest_command.slack_alert
      data:
        message: "{{ '{{' }} \"✅ Smoke cleared — \" ~ (area_name(trigger.entity_id) | default(trigger.to_state.attributes.friendly_name | replace(\" Smoke\", \"\"), true)) {{ '}}' }}"
  mode: parallel

- id: "shelly_smoke_low_battery"
  alias: "Shelly Smoke - Low Battery"
  trigger:
    - platform: numeric_state
      entity_id:
        - sensor.shellyplussmoke_3076f523fd68_battery
      below: 15
  action:
    - service: rest_command.slack_alert
      data:
        message: "{{ '{{' }} \"🪫 Smoke detector low battery — \" ~ (area_name(trigger.entity_id) | default(trigger.to_state.attributes.friendly_name | replace(\" Battery\", \"\"), true)) ~ \": \" ~ trigger.to_state.state ~ \"%\" {{ '}}' }}"
  mode: parallel

- id: "shelly_smoke_offline"
  alias: "Shelly Smoke - Offline (not reporting)"
  trigger:
    - platform: state
      entity_id:
        - binary_sensor.shellyplussmoke_3076f523fd68_smoke
      to: "unavailable"
      for:
        hours: 26
  action:
    - service: rest_command.slack_alert
      data:
        message: "{{ '{{' }} \"⚠️ Smoke detector OFFLINE (not reporting) — \" ~ (area_name(trigger.entity_id) | default(trigger.to_state.attributes.friendly_name | replace(\" Smoke\", \"\"), true)) {{ '}}' }}"
  mode: parallel

- id: "shelly_smoke_online_recovery"
  alias: "Shelly Smoke - Back Online"
  trigger:
    - platform: state
      entity_id:
        - binary_sensor.shellyplussmoke_3076f523fd68_smoke
      from: "unavailable"
  action:
    - service: rest_command.slack_notify
      data:
        message: "{{ '{{' }} \"✅ Smoke detector back online — \" ~ (area_name(trigger.entity_id) | default(trigger.to_state.attributes.friendly_name | replace(\" Smoke\", \"\"), true)) {{ '}}' }}"
  mode: parallel

# ── Amp power control ──────────────────────────────────────────────────────────
# Drive the Pioneer's Shelly plug from source activity. binary_sensor.amp_source_active
# is the OR of all inputs (hifipi AirPlay/Spotify/MPD playing, or the TV powered on).
# Input selection (TV vs Pi) is a future job for the RM IR blaster, keyed off
# sensor.amp_active_source — not wired here yet.
- id: "amp_power_on"
  alias: "Amp - power on when a source is active"
  trigger:
    - platform: state
      entity_id: binary_sensor.amp_source_active
      to: "on"
  condition:
    - condition: state
      entity_id: switch.living_room_shellyplugsg3_pioneer
      state: "off"
  action:
    - service: switch.turn_on
      target:
        entity_id: switch.living_room_shellyplugsg3_pioneer
  mode: single

# 5-minute grace so brief gaps (track changes, short TV pauses) don't cut the amp.
- id: "amp_power_off"
  alias: "Amp - power off when idle"
  trigger:
    - platform: state
      entity_id: binary_sensor.amp_source_active
      to: "off"
      for:
        minutes: 5
  condition:
    - condition: state
      entity_id: switch.living_room_shellyplugsg3_pioneer
      state: "on"
  action:
    - service: switch.turn_off
      target:
        entity_id: switch.living_room_shellyplugsg3_pioneer
  mode: single

# After an HA restart, triggers don't fire for the startup state-settle, so the
# plug can be left out of sync with the sources. Reconcile once entities have
# reconnected (~30s covers MQTT/androidtv/MPD coming back).
- id: "amp_reconcile_on_start"
  alias: "Amp - reconcile plug on HA start"
  trigger:
    - platform: homeassistant
      event: start
  action:
    - delay: "00:00:30"
    - if:
        - condition: state
          entity_id: binary_sensor.amp_source_active
          state: "on"
      then:
        - service: switch.turn_on
          target:
            entity_id: switch.living_room_shellyplugsg3_pioneer
      else:
        - service: switch.turn_off
          target:
            entity_id: switch.living_room_shellyplugsg3_pioneer
  mode: single
