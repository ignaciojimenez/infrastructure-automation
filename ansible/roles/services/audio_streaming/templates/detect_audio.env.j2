# Managed by Ansible — MQTT credentials for detect_audio now-playing state.
# Loaded by detect_audio.service via EnvironmentFile; this file is mode 0600
# to keep the broker credentials out of the world-readable script and unit.
MQTT_BROKER={{ vinyl_mqtt_broker }}
MQTT_PORT={{ vinyl_mqtt_port }}
MQTT_USERNAME={{ vault_mqtt_username }}
MQTT_PASSWORD={{ vault_mqtt_password }}
MQTT_TOPIC=vinyl/{{ ansible_hostname }}
